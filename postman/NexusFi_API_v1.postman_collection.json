							"mode": "raw",
							"raw": "{\n    \"email\": \"wrong@email.com\",\n    \"password\": \"wrongpassword\"\n}"
						},
						"url": {
							"raw": "{{base_url}}{{api_path}}/auth/login",
							"host": ["{{base_url}}{{api_path}}"],
							"path": ["auth", "login"]
						},
						"description": "Negative test: Login with invalid credentials should fail."
					},
					"response": []
				}
			]
		},
