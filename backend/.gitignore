# NexusFi backend .gitignore
# (IDE, OS, and env files are handled by root .gitignore)

# Java/Maven build outputs
target/
out/
build/
dist/
*.class
*.jar
*.war
*.ear
*.nar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Logs
logs/
*.log
*.log.*

# Secrets and credentials
secrets/
credentials/
*.pem
*.key
*.cert
*.crt
*.p12
*.jks

# Local Spring config overlays
src/main/resources/application-local.yml
src/main/resources/application-*.local.yml
spring-boot-devtools.properties

# Databases and dumps
*.db
*.sqlite
*.sqlite3
*.sql.backup
database_backup_*

# Temporary/cache files
*.tmp
*.temp
*.swp
*.swo
*.bak
*.cache
*.pid
*.pid.lock

# Coverage and generated docs
coverage/
.nyc_output/
*.lcov
*.coverage
.coverage.*
docs/_build/
site/

