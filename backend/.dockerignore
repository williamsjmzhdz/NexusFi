# Docker ignore file
# Excludes unnecessary files from Docker build context

# Build outputs
target/
*.jar
*.war
*.class

# IDE files
.idea/
*.iml
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# Documentation
docs/
*.md
!README.md

# Logs
logs/
*.log

# Test files
postman/

# Local configuration
application-dev.yml
*.local

# OS files
.DS_Store
Thumbs.db

# Database
database/
